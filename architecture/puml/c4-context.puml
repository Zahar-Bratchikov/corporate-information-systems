@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Диаграмма системного контекста — ИС УПЗ IT (расширенная)

' Люди (роли)
Person(admin, "Администратор", "Настройка системы, управление пользователями, ролями и справочниками")
Person(pm, "Руководитель проекта / Тимлид", "Планирование и контроль проектов, управление задачами, отчёты")
Person(dev, "Разработчик / QA", "Выполнение задач разработки и тестирования, работа со своими задачами")
Person(observer, "Наблюдатель", "Просмотр статусов проектов и задач, получение отчётов")

' Основная система
System(system, "ИС УПЗ IT", "Управление IT-проектами и задачами: планирование, учёт, отчётность, разграничение доступа")

' Внешние системы
System_Ext(auth, "Корпоративная система аутентификации", "LDAP/AD: проверка логина/пароля и ролей пользователей")
System_Ext(office, "Офисные приложения", "MS Word, MS Excel, PDF-просмотр: открытие сформированных отчётных файлов")

' Взаимодействия людей с системой
Rel(admin, system, "Администрирование, настройка, отчёты", "Веб-интерфейс (HTTPS)")
Rel(pm, system, "Планирование проектов, управление задачами, отчёты", "Веб-интерфейс (HTTPS)")
Rel(dev, system, "Просмотр и обновление своих задач", "Веб-интерфейс (HTTPS)")
Rel(observer, system, "Просмотр статусов и формирование отчётов", "Веб-интерфейс (HTTPS)")

' Взаимодействия системы с внешними системами
Rel(system, auth, "Аутентификация пользователей и получение ролей", "LDAP/LDAPS")
Rel(system, office, "Экспорт отчётов в файлы DOCX/XLSX/PDF", "Файлы")

@enduml
